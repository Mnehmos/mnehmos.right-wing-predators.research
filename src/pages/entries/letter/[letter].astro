---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import FilterSidebar from '../../../components/FilterSidebar.astro';
import MobileFilterSheet from '../../../components/MobileFilterSheet.astro';
import SearchBar from '../../../components/SearchBar.astro';
import AlphabetNav from '../../../components/AlphabetNav.astro';
import {
  getNormalizedEntries,
  getLettersWithEntries,
  getFacetCounts,
} from '../../../utils/entries-index';

const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  return 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').map((letter) => ({
    params: { letter: letter.toLowerCase() },
    props: { letter: letter.toUpperCase() },
  }));
}

interface Props {
  letter: string;
}

const { letter } = Astro.props;

const allEntries = await getNormalizedEntries();
const lettersWithEntries = getLettersWithEntries(allEntries);
const facets = getFacetCounts(allEntries);
const crimes = facets.crimes.map(([n]) => n);
const positions = facets.positions.map(([n]) => n);
const tags = facets.tags.map(([n]) => n);

// SSR: show the first 48 entries starting with this letter, sorted alphabetically.
// Client engine hydrates with ?letter=X state so further filter/sort works on the full dataset.
const letterEntries = allEntries.filter((e) => e.firstLetter === letter);
const initialEntries = letterEntries.slice(0, 48);
const totalForLetter = letterEntries.length;
const totalEntries = allEntries.length;

const pageTitle = `Browse Entries — ${letter}`;
---

<BaseLayout title={pageTitle}>
  <div class="mb-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold mb-2 font-display text-stone-800 dark:text-stone-100">
          Browse Entries <span class="text-copper ml-1">({letter})</span>
        </h1>
        <p class="text-stone-600 dark:text-stone-400">
          <span class="text-stone-800 dark:text-stone-100 font-medium">{totalForLetter.toLocaleString()}</span>
          entries starting with "{letter}"
          <span class="ml-1 text-sm">· {totalEntries.toLocaleString()} total</span>
        </p>
      </div>
      <div class="flex items-center gap-3">
        <label for="sort-select" class="text-sm text-stone-600 dark:text-stone-400">Sort:</label>
        <select
          id="sort-select"
          class="bg-stone-100 dark:bg-stone-800 border border-stone-300 dark:border-stone-700 rounded-lg px-3 py-2 text-sm text-stone-800 dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-copper focus:border-copper min-h-[44px]"
        >
          <option value="name-asc">Name (A–Z)</option>
          <option value="name-desc">Name (Z–A)</option>
          <option value="notability">Notability (most documented)</option>
          <option value="needs-research">Needs research first</option>
        </select>
      </div>
    </div>

    <div class="mb-4">
      <AlphabetNav lettersWithEntries={lettersWithEntries} currentLetter={letter} baseUrl={`${base}entries`} />
    </div>

    <div class="lg:hidden mb-4">
      <SearchBar placeholder="Search entries..." size="md" />
    </div>
  </div>

  <!-- Pre-seed URL state for the client engine -->
  <meta name="initial-letter" content={letter} data-initial />

  <div id="active-filter-bar" class="hidden flex flex-wrap gap-2 mb-4" role="region" aria-label="Active filters"></div>

  <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
    <div class="hidden lg:block lg:w-72 flex-shrink-0">
      <FilterSidebar crimes={crimes} positions={positions} tags={tags} />
    </div>

    <div class="flex-1 min-w-0">
      <div
        id="entries-meta"
        class="mb-4 text-sm text-stone-600 dark:text-stone-400"
        aria-live="polite"
        aria-atomic="true"
      >
        Showing {Math.min(initialEntries.length, totalForLetter)} of {totalForLetter.toLocaleString()} entries
      </div>

      <div id="entries-grid" class="entries-grid grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4">
        {initialEntries.map((entry) => (
          <div
            class="entry-cell"
            data-entry-card
            data-crimes={entry.crimes.join(',')}
            data-positions={entry.positions.join(',')}
            data-tags={entry.tags.join(',')}
          >
            <EntryCard
              name={entry.name}
              slug={entry.slug}
              positions={entry.positions}
              crimes={entry.crimes}
              tags={entry.tags}
              sourceCount={entry.sourceCount}
              needsResearch={entry.needsResearch}
            />
          </div>
        ))}
      </div>

      {initialEntries.length === 0 && (
        <div class="text-center py-12">
          <div class="text-4xl mb-4" aria-hidden="true">🔍</div>
          <h2 class="text-lg font-semibold text-stone-800 dark:text-stone-100 mb-2">No entries starting with "{letter}"</h2>
          <p class="text-stone-600 dark:text-stone-400 text-sm mb-4">Try selecting a different letter</p>
          <a href={`${base}entries/`} class="btn btn-primary no-underline">View All Entries</a>
        </div>
      )}

      <div id="page-controls"></div>
    </div>
  </div>

  <MobileFilterSheet crimes={crimes} positions={positions} tags={tags} />
</BaseLayout>

<script>
  import '../../../scripts/browse-client';
</script>

<style>
  .entries-grid {
    grid-auto-rows: 170px;
  }
  .entry-cell {
    height: 100%;
  }
  .entry-cell > * {
    height: 100%;
  }
</style>
