---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import EntryCard from '../../../components/EntryCard.astro';
import FilterSidebar from '../../../components/FilterSidebar.astro';
import Pagination from '../../../components/Pagination.astro';
import SearchBar from '../../../components/SearchBar.astro';
import AlphabetNav from '../../../components/AlphabetNav.astro';
import { getCollection } from 'astro:content';

// Base path for all internal links
const base = import.meta.env.BASE_URL;

export async function getStaticPaths() {
  const entries = await getCollection('entries');
  
  // Calculate which letters have entries
  const lettersWithEntries = new Set<string>();
  entries.forEach(entry => {
    const firstLetter = entry.data.name.trim().charAt(0).toUpperCase();
    if (/[A-Z]/.test(firstLetter)) {
      lettersWithEntries.add(firstLetter);
    }
  });
  
  // Generate paths for all 26 letters (A-Z)
  // We generate all letters even if empty, so URLs are predictable
  return 'ABCDEFGHIJKLMNOPQRSTUVWXYZ'.split('').map(letter => ({
    params: { letter: letter.toLowerCase() },
    props: { 
      letter: letter.toUpperCase(),
      lettersWithEntries
    }
  }));
}

interface Props {
  letter: string;
  lettersWithEntries: Set<string>;
}

const { letter, lettersWithEntries } = Astro.props;

// This page is always page 1 for the letter
// Pages 2+ are handled by /entries/letter/[letter]/page/[page].astro
const ENTRIES_PER_PAGE = 48;
const currentPage = 1;

const entries = await getCollection('entries');

// Sort alphabetically by name (trim whitespace for consistent ordering)
let sortedEntries = entries.sort((a, b) =>
  a.data.name.trim().localeCompare(b.data.name.trim())
);

// Filter by the current letter
sortedEntries = sortedEntries.filter(entry =>
  entry.data.name.trim().charAt(0).toUpperCase() === letter
);

// Calculate pagination - always page 1
const totalEntries = sortedEntries.length;
const totalPages = Math.ceil(totalEntries / ENTRIES_PER_PAGE);
const startIndex = 0;
const endIndex = ENTRIES_PER_PAGE;
const paginatedEntries = sortedEntries.slice(startIndex, endIndex);

// Get all unique filter options with counts (from all entries, not filtered)
const crimeCounts = new Map<string, number>();
const positionCounts = new Map<string, number>();
const tagCounts = new Map<string, number>();

entries.forEach(entry => {
  entry.data.crimes.forEach(crime => {
    crimeCounts.set(crime, (crimeCounts.get(crime) || 0) + 1);
  });
  entry.data.positions.forEach(pos => {
    positionCounts.set(pos, (positionCounts.get(pos) || 0) + 1);
  });
  entry.data.tags.forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});

// Sort by count (descending) and get arrays
const crimes = [...crimeCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([name]) => name);

const positions = [...positionCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([name]) => name);

const tags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1])
  .map(([name]) => name);

// Page title with letter filter
const pageTitle = `Browse Entries - ${letter}`;
---

<BaseLayout title={pageTitle}>
  <!-- Page Header -->
  <div class="mb-8">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold mb-2 font-display text-stone-800 dark:text-stone-100">
          Browse Entries
          <span class="text-copper ml-2">({letter})</span>
        </h1>
        <p class="text-stone-600 dark:text-stone-400">
          <span class="text-stone-800 dark:text-stone-100 font-medium">{totalEntries.toLocaleString()}</span> 
          entries starting with "{letter}"
        </p>
      </div>
      
      <!-- Sort Options (future enhancement placeholder) -->
      <div class="flex items-center gap-3">
        <label class="text-sm text-stone-600 dark:text-stone-400">Sort:</label>
        <select 
          id="sort-select"
          class="bg-stone-100 dark:bg-stone-800 border border-stone-300 dark:border-stone-700 rounded-lg px-3 py-2 text-sm text-stone-700 dark:text-stone-300 focus:outline-none focus:border-copper"
        >
          <option value="name-asc">Name (A-Z)</option>
          <option value="name-desc">Name (Z-A)</option>
        </select>
      </div>
    </div>
    
    <!-- Alphabet Navigation -->
    <div class="mb-4">
      <AlphabetNav 
        lettersWithEntries={lettersWithEntries}
        currentLetter={letter}
        baseUrl="/entries"
      />
    </div>
    
    <!-- Search Bar for Browse Page -->
    <div class="lg:hidden mb-6">
      <SearchBar placeholder="Search entries..." size="md" />
    </div>
  </div>

  <!-- Main Content with Sidebar -->
  <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
    <!-- Filter Sidebar (Desktop) -->
    <div class="hidden lg:block lg:w-72 flex-shrink-0">
      <FilterSidebar 
        crimes={crimes}
        positions={positions}
        tags={tags}
      />
    </div>

    <!-- Mobile Filter Toggle -->
    <div class="lg:hidden">
      <button 
        id="mobile-filter-toggle"
        class="w-full flex items-center justify-center gap-2 py-3 bg-stone-200 dark:bg-stone-800 border border-stone-300 dark:border-stone-700 rounded-lg text-stone-700 dark:text-stone-300 hover:bg-stone-300 dark:hover:bg-stone-700 hover:text-copper transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
        </svg>
        Filters
      </button>
      
      <!-- Mobile Filter Panel -->
      <div id="mobile-filter-panel" class="hidden mt-4">
        <FilterSidebar 
          crimes={crimes}
          positions={positions}
          tags={tags}
        />
      </div>
    </div>

    <!-- Entry Grid -->
    <div class="flex-1 min-w-0">
      <!-- Results Info -->
      <div class="flex items-center justify-between mb-4 text-sm text-stone-600 dark:text-stone-400">
        <span>
          {totalEntries > 0 ? (
            <>Showing {startIndex + 1}–{Math.min(endIndex, totalEntries)} of {totalEntries.toLocaleString()}</>
          ) : (
            <>No entries found</>
          )}
        </span>
        {totalPages > 0 && (
          <span>
            Page {currentPage} of {totalPages}
          </span>
        )}
      </div>

      <!-- Entry Cards Grid - Uniform cell sizing -->
      <div
        id="entries-grid"
        class="entries-grid grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4"
      >
        {paginatedEntries.map((entry) => (
          <div
            class="entry-cell"
            data-entry-card
            data-crimes={entry.data.crimes.join(',')}
            data-positions={entry.data.positions.join(',')}
            data-tags={entry.data.tags.join(',')}
          >
            <EntryCard
              name={entry.data.name}
              slug={entry.slug}
              positions={entry.data.positions}
              crimes={entry.data.crimes}
              tags={entry.data.tags}
            />
          </div>
        ))}
      </div>

      <!-- Empty State (shown when filters result in no entries) -->
      {paginatedEntries.length === 0 && (
        <div class="text-center py-12">
          <div class="text-4xl mb-4">🔍</div>
          <h3 class="text-lg font-semibold text-stone-800 dark:text-stone-100 mb-2">
            No entries starting with "{letter}"
          </h3>
          <p class="text-stone-600 dark:text-stone-400 text-sm mb-4">
            Try selecting a different letter
          </p>
          <a 
            href="/entries" 
            class="inline-block px-4 py-2 bg-copper text-white rounded-lg hover:bg-copper-light transition-colors no-underline"
          >
            View All Entries
          </a>
        </div>
      )}

      <!-- Pagination -->
      {totalPages > 1 && (
        <Pagination
          currentPage={currentPage}
          totalPages={totalPages}
          baseUrl={`/entries/letter/${letter.toLowerCase()}`}
          letterFilter={letter.toLowerCase()}
        />
      )}
    </div>
  </div>
</BaseLayout>

<script>
  // Mobile filter toggle
  const filterToggle = document.getElementById('mobile-filter-toggle');
  const filterPanel = document.getElementById('mobile-filter-panel');
  
  filterToggle?.addEventListener('click', () => {
    filterPanel?.classList.toggle('hidden');
    const isOpen = !filterPanel?.classList.contains('hidden');
    filterToggle.innerHTML = isOpen 
      ? `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg> Hide Filters`
      : `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg> Filters`;
  });

  // Sort functionality
  const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
  const grid = document.getElementById('entries-grid');
  
  sortSelect?.addEventListener('change', () => {
    const cards = Array.from(grid?.querySelectorAll('[data-entry-card]') || []);
    const sortValue = sortSelect.value;
    
    cards.sort((a, b) => {
      const nameA = a.querySelector('h2')?.textContent || '';
      const nameB = b.querySelector('h2')?.textContent || '';
      
      if (sortValue === 'name-asc') {
        return nameA.localeCompare(nameB);
      } else {
        return nameB.localeCompare(nameA);
      }
    });
    
    cards.forEach(card => grid?.appendChild(card));
  });
</script>

<style>
  /* Uniform grid cells - ensures all cells are same height */
  .entries-grid {
    /* Auto-fit rows with consistent row height */
    grid-auto-rows: 152px;
  }

  .entry-cell {
    /* Ensure cell contents fill the grid cell */
    height: 100%;
  }

  .entry-cell > * {
    /* EntryCard fills the cell */
    height: 100%;
  }
</style>
