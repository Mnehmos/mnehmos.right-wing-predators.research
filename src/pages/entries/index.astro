---
import BaseLayout from '../../layouts/BaseLayout.astro';
import EntryCard from '../../components/EntryCard.astro';
import FilterSidebar from '../../components/FilterSidebar.astro';
import MobileFilterSheet from '../../components/MobileFilterSheet.astro';
import SearchBar from '../../components/SearchBar.astro';
import AlphabetNav from '../../components/AlphabetNav.astro';
import {
  getNormalizedEntries,
  getLettersWithEntries,
  getFacetCounts,
  getTopByScore,
} from '../../utils/entries-index';

const base = import.meta.env.BASE_URL;

const entries = await getNormalizedEntries();
const lettersWithEntries = getLettersWithEntries(entries);
const facets = getFacetCounts(entries);
const crimes = facets.crimes.map(([name]) => name);
const positions = facets.positions.map(([name]) => name);
const tags = facets.tags.map(([name]) => name);

// SSR shell: default view is "Notability" sort, first 48 entries.
// Client engine takes over on mount and handles all filtering/pagination.
const initialEntries = getTopByScore(entries, 48);
const totalEntries = entries.length;
const needsResearchCount = entries.filter((e) => e.needsResearch).length;

const pageTitle = 'Browse All Entries';
---

<BaseLayout title={pageTitle}>
  <!-- Page Header -->
  <div class="mb-6">
    <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-4 mb-4">
      <div>
        <h1 class="text-3xl md:text-4xl font-bold mb-2 font-display text-stone-800 dark:text-stone-100">
          Browse Entries
        </h1>
        <p class="text-stone-600 dark:text-stone-400">
          <span class="text-stone-800 dark:text-stone-100 font-medium">{totalEntries.toLocaleString()}</span>
          documented entries
          {needsResearchCount > 0 && (
            <span class="ml-2 text-sm inline-flex items-center gap-1">
              <span aria-hidden="true">·</span>
              <span>{needsResearchCount.toLocaleString()} need research</span>
            </span>
          )}
        </p>
      </div>

      <div class="flex items-center gap-3">
        <label for="sort-select" class="text-sm text-stone-600 dark:text-stone-400">Sort:</label>
        <select
          id="sort-select"
          class="bg-stone-100 dark:bg-stone-800 border border-stone-300 dark:border-stone-700 rounded-lg px-3 py-2 text-sm text-stone-800 dark:text-stone-100 focus:outline-none focus:ring-2 focus:ring-copper focus:border-copper min-h-[44px]"
        >
          <option value="notability">Notability (most documented)</option>
          <option value="name-asc">Name (A–Z)</option>
          <option value="name-desc">Name (Z–A)</option>
          <option value="needs-research">Needs research first</option>
        </select>
      </div>
    </div>

    <div class="mb-4">
      <AlphabetNav lettersWithEntries={lettersWithEntries} baseUrl={`${base}entries`} />
    </div>

    <div class="lg:hidden mb-4">
      <SearchBar placeholder="Search entries..." size="md" />
    </div>
  </div>

  <!-- Active filter chips -->
  <div id="active-filter-bar" class="hidden flex flex-wrap gap-2 mb-4" role="region" aria-label="Active filters"></div>

  <!-- Main Content with Sidebar -->
  <div class="flex flex-col lg:flex-row gap-6 lg:gap-8">
    <!-- Filter Sidebar (Desktop only) -->
    <div class="hidden lg:block lg:w-72 flex-shrink-0">
      <FilterSidebar crimes={crimes} positions={positions} tags={tags} />
    </div>

    <!-- Entry Grid -->
    <div class="flex-1 min-w-0">
      <div
        id="entries-meta"
        class="mb-4 text-sm text-stone-600 dark:text-stone-400"
        aria-live="polite"
        aria-atomic="true"
      >
        Showing {initialEntries.length} of {totalEntries.toLocaleString()} entries
      </div>

      <div
        id="entries-grid"
        class="entries-grid grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-3 gap-4"
      >
        {initialEntries.map((entry) => (
          <div
            class="entry-cell"
            data-entry-card
            data-crimes={entry.crimes.join(',')}
            data-positions={entry.positions.join(',')}
            data-tags={entry.tags.join(',')}
          >
            <EntryCard
              name={entry.name}
              slug={entry.slug}
              positions={entry.positions}
              crimes={entry.crimes}
              tags={entry.tags}
              sourceCount={entry.sourceCount}
              needsResearch={entry.needsResearch}
            />
          </div>
        ))}
      </div>

      <!-- Pagination rendered by client engine -->
      <div id="page-controls"></div>
    </div>
  </div>

  <!-- Mobile filter sheet (sticky bar + drawer) -->
  <MobileFilterSheet crimes={crimes} positions={positions} tags={tags} />
</BaseLayout>

<script>
  import '../../scripts/browse-client';
</script>

<style>
  .entries-grid {
    grid-auto-rows: 170px;
  }
  .entry-cell {
    height: 100%;
  }
  .entry-cell > * {
    height: 100%;
  }
</style>
