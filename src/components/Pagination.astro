---
interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
  letterFilter?: string; // Optional letter filter for letter-specific pagination
}

const { currentPage, totalPages, baseUrl, letterFilter } = Astro.props;

// Calculate which page numbers to show
const getPageNumbers = () => {
  const pages: (number | string)[] = [];
  const showPages = 5; // How many page numbers to show
  
  if (totalPages <= showPages + 2) {
    // Show all pages if there aren't many
    for (let i = 1; i <= totalPages; i++) {
      pages.push(i);
    }
  } else {
    // Always show first page
    pages.push(1);
    
    // Calculate range around current page
    let start = Math.max(2, currentPage - 1);
    let end = Math.min(totalPages - 1, currentPage + 1);
    
    // Adjust if at the edges
    if (currentPage <= 3) {
      end = Math.min(totalPages - 1, showPages - 1);
    } else if (currentPage >= totalPages - 2) {
      start = Math.max(2, totalPages - showPages + 2);
    }
    
    // Add ellipsis after first page if needed
    if (start > 2) {
      pages.push('...');
    }
    
    // Add middle pages
    for (let i = start; i <= end; i++) {
      pages.push(i);
    }
    
    // Add ellipsis before last page if needed
    if (end < totalPages - 1) {
      pages.push('...');
    }
    
    // Always show last page
    pages.push(totalPages);
  }
  
  return pages;
};

const pageNumbers = getPageNumbers();

// Generate static URLs for pagination
// Page 1: /entries/ or /entries/letter/m/
// Page 2+: /entries/page/2/ or /entries/letter/m/page/2/
const getPageUrl = (page: number) => {
  if (letterFilter) {
    // Letter-filtered pagination
    if (page === 1) {
      return `/entries/letter/${letterFilter}/`;
    }
    return `/entries/letter/${letterFilter}/page/${page}/`;
  } else {
    // All entries pagination
    if (page === 1) {
      return '/entries/';
    }
    return `/entries/page/${page}/`;
  }
};
---

{totalPages > 1 && (
  <nav class="flex items-center justify-center gap-1 mt-8" aria-label="Pagination">
    <!-- Previous Button -->
    {currentPage > 1 ? (
      <a
        href={getPageUrl(currentPage - 1)}
        class="flex items-center gap-1 px-3 py-2 rounded-lg bg-stone-200 dark:bg-stone-800 border border-stone-300 dark:border-stone-700 text-stone-700 dark:text-stone-300 hover:bg-stone-300 dark:hover:bg-stone-700 hover:text-copper hover:border-copper transition-colors no-underline"
        aria-label="Previous page"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">Prev</span>
      </a>
    ) : (
      <span class="flex items-center gap-1 px-3 py-2 rounded-lg bg-stone-100 dark:bg-stone-800/50 border border-stone-200 dark:border-stone-700/50 text-stone-400 dark:text-stone-600 cursor-not-allowed">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        <span class="hidden sm:inline">Prev</span>
      </span>
    )}
    
    <!-- Page Numbers -->
    <div class="flex items-center gap-1">
      {pageNumbers.map((page) => (
        page === '...' ? (
          <span class="px-2 py-2 text-stone-400 dark:text-stone-500">...</span>
        ) : page === currentPage ? (
          <span class="px-3 py-2 rounded-lg bg-copper text-white font-medium min-w-[2.5rem] text-center">
            {page}
          </span>
        ) : (
          <a
            href={getPageUrl(page as number)}
            class="px-3 py-2 rounded-lg bg-stone-200 dark:bg-stone-800 border border-stone-300 dark:border-stone-700 text-stone-700 dark:text-stone-300 hover:bg-stone-300 dark:hover:bg-stone-700 hover:text-copper hover:border-copper transition-colors no-underline min-w-[2.5rem] text-center"
          >
            {page}
          </a>
        )
      ))}
    </div>
    
    <!-- Next Button -->
    {currentPage < totalPages ? (
      <a
        href={getPageUrl(currentPage + 1)}
        class="flex items-center gap-1 px-3 py-2 rounded-lg bg-stone-200 dark:bg-stone-800 border border-stone-300 dark:border-stone-700 text-stone-700 dark:text-stone-300 hover:bg-stone-300 dark:hover:bg-stone-700 hover:text-copper hover:border-copper transition-colors no-underline"
        aria-label="Next page"
      >
        <span class="hidden sm:inline">Next</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    ) : (
      <span class="flex items-center gap-1 px-3 py-2 rounded-lg bg-stone-100 dark:bg-stone-800/50 border border-stone-200 dark:border-stone-700/50 text-stone-400 dark:text-stone-600 cursor-not-allowed">
        <span class="hidden sm:inline">Next</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </span>
    )}
  </nav>
)}

<!-- Page Info -->
<div class="text-center text-sm text-stone-500 mt-4">
  Page {currentPage} of {totalPages}
</div>
