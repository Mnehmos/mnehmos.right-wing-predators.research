---
interface Props {
  crimes: string[];
  positions: string[];
  tags: string[];
  variant?: 'desktop' | 'mobile';
}

const { crimes, positions, tags, variant = 'desktop' } = Astro.props;

// Top facets: the client engine filters the full dataset, but we display the
// most common values in the sidebar to keep the UI scannable.
const topCrimes = crimes.slice(0, 20);
const topPositions = positions.slice(0, 20);
const topTags = tags.slice(0, 15);

const idPrefix = variant === 'mobile' ? 'm-' : '';
---

<aside
  id={`${idPrefix}filter-sidebar`}
  class:list={[
    'filter-sidebar bg-stone-100 dark:bg-stone-800/50 border border-stone-200 dark:border-stone-700/50 rounded-xl p-5',
    variant === 'desktop' ? 'sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto' : '',
  ]}
  aria-labelledby={`${idPrefix}filter-heading`}
>
  <div class="flex items-center justify-between mb-4">
    <h2 id={`${idPrefix}filter-heading`} class="text-lg font-bold text-stone-800 dark:text-stone-100 font-display">Filters</h2>
    <button
      id={`${idPrefix === '' ? 'clear-filters' : idPrefix + 'clear-filters'}`}
      class="text-xs text-stone-500 dark:text-stone-400 hover:text-copper focus:outline-none focus:ring-2 focus:ring-copper focus:ring-offset-2 focus:ring-offset-stone-100 dark:focus:ring-offset-stone-800 rounded px-1 transition-colors"
      type="button"
    >
      Clear all
    </button>
  </div>

  <!-- Crime Type Filter -->
  <fieldset class="mb-6">
    <legend class="w-full">
      <button
        class="filter-section-toggle flex items-center justify-between w-full text-left mb-3"
        data-section={`${idPrefix}crimes`}
        aria-expanded="true"
        aria-controls={`${idPrefix}crimes-section`}
        type="button"
      >
        <span class="text-sm font-semibold text-stone-700 dark:text-stone-200 uppercase tracking-wide">Crime Type</span>
        <svg class="w-4 h-4 text-stone-400 dark:text-stone-500 transition-transform" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </legend>
    <div id={`${idPrefix}crimes-section`} class="space-y-1.5 max-h-64 overflow-y-auto scrollbar-thin">
      {topCrimes.map((crime) => (
        <label class="flex items-center gap-2 cursor-pointer group py-1 min-h-[32px]">
          <input
            type="checkbox"
            name="crime"
            value={crime}
            class="filter-checkbox w-4 h-4 rounded border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-700 text-copper focus:ring-2 focus:ring-copper focus:ring-offset-stone-100 dark:focus:ring-offset-stone-800"
          />
          <span class="text-sm text-stone-700 dark:text-stone-300 group-hover:text-copper transition-colors truncate">
            {crime}
          </span>
        </label>
      ))}
    </div>
  </fieldset>

  <!-- Position Filter -->
  <fieldset class="mb-6">
    <legend class="w-full">
      <button
        class="filter-section-toggle flex items-center justify-between w-full text-left mb-3"
        data-section={`${idPrefix}positions`}
        aria-expanded="true"
        aria-controls={`${idPrefix}positions-section`}
        type="button"
      >
        <span class="text-sm font-semibold text-stone-700 dark:text-stone-200 uppercase tracking-wide">Position</span>
        <svg class="w-4 h-4 text-stone-400 dark:text-stone-500 transition-transform" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </legend>
    <div id={`${idPrefix}positions-section`} class="space-y-1.5 max-h-64 overflow-y-auto scrollbar-thin">
      {topPositions.map((position) => (
        <label class="flex items-center gap-2 cursor-pointer group py-1 min-h-[32px]">
          <input
            type="checkbox"
            name="position"
            value={position}
            class="filter-checkbox w-4 h-4 rounded border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-700 text-copper focus:ring-2 focus:ring-copper focus:ring-offset-stone-100 dark:focus:ring-offset-stone-800"
          />
          <span class="text-sm text-stone-700 dark:text-stone-300 group-hover:text-copper transition-colors truncate" title={position}>
            {position.length > 40 ? position.substring(0, 40) + '…' : position}
          </span>
        </label>
      ))}
    </div>
  </fieldset>

  <!-- Tag Filter -->
  {topTags.length > 0 && (
    <fieldset class="mb-2">
      <legend class="w-full">
        <button
          class="filter-section-toggle flex items-center justify-between w-full text-left mb-3"
          data-section={`${idPrefix}tags`}
          aria-expanded="true"
          aria-controls={`${idPrefix}tags-section`}
          type="button"
        >
          <span class="text-sm font-semibold text-stone-700 dark:text-stone-200 uppercase tracking-wide">Tags</span>
          <svg class="w-4 h-4 text-stone-400 dark:text-stone-500 transition-transform" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </button>
      </legend>
      <div id={`${idPrefix}tags-section`} class="space-y-1.5 max-h-48 overflow-y-auto scrollbar-thin">
        {topTags.map((tag) => (
          <label class="flex items-center gap-2 cursor-pointer group py-1 min-h-[32px]">
            <input
              type="checkbox"
              name="tag"
              value={tag}
              class="filter-checkbox w-4 h-4 rounded border-stone-300 dark:border-stone-600 bg-white dark:bg-stone-700 text-copper focus:ring-2 focus:ring-copper focus:ring-offset-stone-100 dark:focus:ring-offset-stone-800"
            />
            <span class="text-sm text-stone-700 dark:text-stone-300 group-hover:text-copper transition-colors truncate" title={tag}>
              {tag}
            </span>
          </label>
        ))}
      </div>
    </fieldset>
  )}
</aside>

<script>
  // Section collapse/expand with proper ARIA.
  // Only runs once per page — guard against double-binding when the mobile
  // sheet re-mounts the sidebar inside its drawer.
  function bindSectionToggles() {
    document.querySelectorAll<HTMLButtonElement>('.filter-section-toggle').forEach((btn) => {
      if (btn.dataset.bound === '1') return;
      btn.dataset.bound = '1';
      btn.addEventListener('click', () => {
        const section = btn.getAttribute('data-section');
        if (!section) return;
        const sectionDiv = document.getElementById(`${section}-section`);
        const arrow = btn.querySelector('svg');
        if (!sectionDiv) return;
        const isOpen = !sectionDiv.classList.contains('hidden');
        sectionDiv.classList.toggle('hidden');
        arrow?.classList.toggle('rotate-180');
        btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true');
      });
    });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', bindSectionToggles);
  } else {
    bindSectionToggles();
  }
</script>
