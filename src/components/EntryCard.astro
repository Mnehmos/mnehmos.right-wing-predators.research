---
interface Props {
  name: string;
  slug: string;
  positions?: string[];
  crimes?: string[];
  tags?: string[];
  sourceCount?: number;
  needsResearch?: boolean;
}

const base = import.meta.env.BASE_URL;

const {
  name,
  slug,
  positions = [],
  crimes = [],
  tags = [],
  sourceCount = 0,
  needsResearch = false,
} = Astro.props;

const displayCrimes = crimes.slice(0, 2);
const remainingCrimes = crimes.length - displayCrimes.length;

const displayPositions = positions.slice(0, 2);
const remainingPositions = positions.length - displayPositions.length;

const truncatePosition = (text: string, maxLen: number = 25) => {
  if (text.length <= maxLen) return text;
  return text.substring(0, maxLen) + '…';
};
---

<article class="entry-card group relative bg-stone-100 dark:bg-stone-800/50 border border-stone-200 dark:border-stone-700/50 rounded-xl overflow-hidden transition-all duration-300 hover:bg-stone-200 dark:hover:bg-stone-800 hover:border-copper hover:shadow-xl hover:shadow-stone-900/20 dark:hover:shadow-stone-900/50 hover:-translate-y-1 focus-within:ring-2 focus-within:ring-copper">
  <a
    href={`${base}entries/${slug}/`}
    class="card-link block p-5 no-underline h-full focus:outline-none"
    aria-label={`View entry for ${name}`}
  >
    <div class="card-title-area">
      <h2 class="card-title text-lg font-bold text-stone-800 dark:text-stone-100 group-hover:text-copper transition-colors">
        {name}
      </h2>
    </div>

    <!-- Meta row: sources + research flag -->
    <div class="card-meta-row">
      {sourceCount > 1 && (
        <span class="badge badge-sources" title={`${sourceCount} sources`}>
          <svg class="w-3 h-3" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
          </svg>
          {sourceCount}
        </span>
      )}
      {needsResearch && (
        <span class="badge badge-research" title="Sparse entry — needs additional sources">
          <svg class="w-3 h-3" aria-hidden="true" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
          </svg>
          Needs research
        </span>
      )}
    </div>

    <!-- Positions -->
    <div class="card-badges-area positions-area">
      {displayPositions.length > 0 ? (
        <div class="badges-row">
          {displayPositions.map((position) => (
            <span class="badge badge-position">
              {truncatePosition(position)}
            </span>
          ))}
          {remainingPositions > 0 && (
            <span class="badge badge-more">+{remainingPositions}</span>
          )}
        </div>
      ) : (
        <div class="badge-placeholder">&nbsp;</div>
      )}
    </div>

    <!-- Crimes -->
    <div class="card-badges-area crimes-area">
      {displayCrimes.length > 0 ? (
        <div class="badges-row">
          {displayCrimes.map((crime) => (
            <span class="badge badge-crime">{crime}</span>
          ))}
          {remainingCrimes > 0 && (
            <span class="badge badge-more">+{remainingCrimes}</span>
          )}
        </div>
      ) : (
        <div class="badge-placeholder">&nbsp;</div>
      )}
    </div>

    <!-- Arrow indicator -->
    <div class="absolute top-5 right-4 text-stone-400 dark:text-stone-500 group-hover:text-copper transition-all group-hover:translate-x-1" aria-hidden="true">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
      </svg>
    </div>
  </a>
</article>
